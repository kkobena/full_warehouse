<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fitsSystemWindows="true"
    tools:context=".ui.activity.UnifiedSaleActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/nouvelle_vente"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="120dp">

            <!-- Plafond Vente Warning Banner -->
            <LinearLayout
                android:id="@+id/plafondWarningBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/warning_light"
                android:padding="8dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_warning"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Warning" />

                <TextView
                    android:id="@+id/tvPlafondWarningMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/gray_800"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Sale Type Selector -->
            <include
                android:id="@+id/includeSaleTypeSelector"
                layout="@layout/include_sale_type_selector" />

            <!-- Customer Zone (mandatory for Assurance/Carnet) -->
            <include
                android:id="@+id/includeCustomerZone"
                layout="@layout/include_customer_zone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <!-- Customer Info Display (shows selected customer + tiers payants + ayant droit) -->
            <include
                android:id="@+id/includeCustomerInfoDisplay"
                layout="@layout/include_customer_info_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <!-- Product Search & Cart -->
            <include
                android:id="@+id/includeProductCart"
                layout="@layout/include_product_cart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Bar with Actions (collapsible) -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <!-- A Payer Row (always visible, prominent for Assurance/Carnet) -->
        <LinearLayout
            android:id="@+id/rowAmountToBePaid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="A payer"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAmountToBePaid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                tools:text="3,000" />

        </LinearLayout>

        <!-- Total Row (always visible, clickable to expand details) -->
        <LinearLayout
            android:id="@+id/headerBottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/ivExpandBottomBar"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_expand_more"
                android:contentDescription="Détails"
                app:tint="@color/text_secondary"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                tools:text="15,000" />

        </LinearLayout>

        <!-- Expandable details section -->
        <LinearLayout
            android:id="@+id/bottomBarDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- TVA Row -->
            <LinearLayout
                android:id="@+id/rowTva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TVA"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvTva"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    tools:text="500 FCFA" />

            </LinearLayout>

            <!-- Remise Row -->
            <LinearLayout
                android:id="@+id/rowRemise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Remise"
                    android:textSize="12sp"
                    android:textColor="@color/success" />

                <TextView
                    android:id="@+id/tvRemise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/success"
                    tools:text="-1,000 FCFA" />

            </LinearLayout>

            <!-- Remise Action Row -->
            <LinearLayout
                android:id="@+id/rowRemiseAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddRemise"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="% Remise"
                    android:textSize="11sp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:iconSize="14dp"
                    app:cornerRadius="14dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCurrentRemise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:closeIconVisible="true"
                    app:chipIcon="@drawable/ic_percentage"
                    app:chipIconTint="@color/white"
                    app:chipBackgroundColor="@color/success"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    tools:text="Remise A (10%)"
                    tools:visibility="visible" />

                <ImageButton
                    android:id="@+id/btnEditRemise"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_edit"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/remise_modifier"
                    android:visibility="gone"
                    app:tint="@color/text_secondary"
                    tools:visibility="visible" />

            </LinearLayout>

            <!-- Tiers Payant Details Container -->
            <LinearLayout
                android:id="@+id/containerTiersPayantDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="2dp"
                android:visibility="gone"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPutOnHold"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/mettre_en_attente"
                android:textSize="12sp"
                android:textAllCaps="false"
                app:icon="@drawable/ic_pause"
                app:iconSize="16dp"
                app:iconGravity="textStart"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinalizeSale"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="@string/finaliser_vente"
                android:textSize="12sp"
                android:textAllCaps="false"
                app:icon="@drawable/ic_check"
                app:iconSize="16dp"
                app:iconGravity="textStart"
                app:cornerRadius="8dp"
                android:backgroundTint="@color/success"
                android:textColor="@color/white" />

        </LinearLayout>

    </LinearLayout>

    <!-- Progress Bar -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminate="true"
        app:indicatorColor="@color/primary"
        tools:visibility="visible" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
