{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PharmaSmart",
  "version": "0.2.3",
 "identifier": "com.kobe.pharmasmart",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "npm run webapp:build:tauri",
    "frontendDist": "../target/classes/static"
  },

  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "config.default.json",
      "backend-url.txt.template",
      "backup/setup-backup-tasks.ps1",
      "backup/remove-backup-tasks.ps1",
      "backup/pharmasmart-backup.exe"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "wix": {
        "language": [ "fr-FR"],
        "fragmentPaths": ["wix/pharmasmart-config.wxs"]
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": [ "French"],
        "displayLanguageSelector": true,
        "installMode": "both"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PharmaSmart",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "minWidth": 1024,
        "minHeight": 768,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; script-src 'self' 'unsafe-inline' 'unsafe-eval' tauri:; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: http: tauri: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* ws://localhost:* http://*:* ws://*:*",
      "capabilities": ["default"]
    }
  }
}
