<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Camera for barcode scanning -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Phone calls for client callback -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <application
        android:name=".PharmaReportApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PharmaReport"
        android:usesCleartextTraffic="true"
        tools:targetApi="36">

        <!-- Splash/Login Activity -->
        <activity
            android:name=".ui.activity.LoginActivity"
            android:exported="true"
            android:screenOrientation="fullSensor"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Dashboard Activity -->
        <activity
            android:name=".ui.activity.DashboardActivity"
            android:exported="false"
            android:label="@string/dashboard_title"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.LoginActivity" />

        <!-- Alerts Activity -->
        <activity
            android:name=".ui.activity.AlertsActivity"
            android:exported="false"
            android:label="@string/alerts_title"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.DashboardActivity" />

        <!-- Todos Activity -->
        <activity
            android:name=".ui.activity.TodosActivity"
            android:exported="false"
            android:label="@string/todos_title"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.DashboardActivity" />

        <!-- Product Search Activity -->
        <activity
            android:name=".ui.activity.ProductSearchActivity"
            android:exported="false"
            android:label="@string/product_search_title"
            android:screenOrientation="fullSensor"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.activity.DashboardActivity" />

        <!-- Product Detail Activity -->
        <activity
            android:name=".ui.activity.ProductDetailActivity"
            android:exported="false"
            android:label="@string/product_detail_title"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.DashboardActivity" />

        <!-- Performance Activity -->
        <activity
            android:name=".ui.activity.PerformanceActivity"
            android:exported="false"
            android:label="@string/performance_title"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.DashboardActivity" />

        <!-- Pharmacist Dashboard Activity (Tableau Pharmacien) -->
        <activity
            android:name=".ui.activity.PharmacistDashboardActivity"
            android:exported="false"
            android:label="@string/report_pharmacist_dashboard"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.DashboardActivity" />

        <!-- Cash Summary Activity (Ticket Z / Récapitulatif Caisse) -->
        <activity
            android:name=".ui.activity.CashSummaryActivity"
            android:exported="false"
            android:label="@string/report_cash_summary"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.DashboardActivity" />

        <!-- Activity Report Activity (Rapport d'Activité) -->
        <activity
            android:name=".ui.activity.ActivityReportActivity"
            android:exported="false"
            android:label="@string/report_activity"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.DashboardActivity" />

        <!-- Cash Balance Activity (Balance Caisse) -->
        <activity
            android:name=".ui.activity.CashBalanceActivity"
            android:exported="false"
            android:label="@string/report_cash_balance"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.DashboardActivity" />

        <!-- TVA Report Activity (Rapport TVA) -->
        <activity
            android:name=".ui.activity.TvaReportActivity"
            android:exported="false"
            android:label="@string/report_vat"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.DashboardActivity" />

        <!-- Tiers Payant Créances Activity (Phase 4 Statistical Reports) -->
        <activity
            android:name=".ui.activity.TiersPayantCreancesActivity"
            android:exported="false"
            android:label="@string/report_tiers_payant"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.ReportsActivity" />

        <!-- Supplier Performance Activity (Phase 4 Statistical Reports) -->
        <activity
            android:name=".ui.activity.SupplierPerformanceActivity"
            android:exported="false"
            android:label="@string/supplier_performance_title"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.ReportsActivity" />

        <!-- Stock Valuation Activity (Phase 4 Statistical Reports) -->
        <activity
            android:name=".ui.activity.StockValuationActivity"
            android:exported="false"
            android:label="@string/stock_valuation_title"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.ReportsActivity" />

        <!-- Profitability Activity (Phase 4 Statistical Reports) -->
        <activity
            android:name=".ui.activity.ProfitabilityActivity"
            android:exported="false"
            android:label="@string/profitability_title"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.ReportsActivity" />

        <!-- Stock Rotation Activity (Phase 4 Statistical Reports) -->
        <activity
            android:name=".ui.activity.StockRotationActivity"
            android:exported="false"
            android:label="@string/stock_rotation_title"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.ReportsActivity" />

        <!-- ABC Pareto Activity (Phase 4 Statistical Reports) -->
        <activity
            android:name=".ui.activity.AbcParetoActivity"
            android:exported="false"
            android:label="@string/abc_pareto_title"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.ReportsActivity" />

        <!-- Reports Menu Activity -->
        <activity
            android:name=".ui.activity.ReportsActivity"
            android:exported="false"
            android:label="@string/nav_reports"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.DashboardActivity" />

        <!-- Barcode Scanner Activity -->
        <activity
            android:name=".ui.activity.BarcodeScannerActivity"
            android:exported="false"
            android:label="@string/scanner_title"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.activity.DashboardActivity" />

        <!-- Server Configuration Activity -->
        <activity
            android:name=".ui.activity.ServerConfigActivity"
            android:exported="false"
            android:label="@string/server_config_title"
            android:screenOrientation="fullSensor"
            android:parentActivityName=".ui.activity.LoginActivity" />

        <!-- Firebase Cloud Messaging Service -->
        <service
            android:name=".service.PharmaFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Dashboard Widget -->
        <receiver
            android:name=".widget.DashboardWidgetProvider"
            android:exported="true"
            android:label="@string/widget_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.kobe.warehouse.reports.ACTION_WIDGET_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_dashboard_info" />
        </receiver>

    </application>

</manifest>
