  <modelVersion>4.0.0</modelVersion>
  <name>PharmaSmart Application</name>

  <packaging>jar</packaging>

  <parent>
    <artifactId>pharmaSmart</artifactId>
    <groupId>com.kobe.warehouse</groupId>
    <relativePath>../pom.xml</relativePath>
    <version>${revision}</version>
  </parent>

  <profiles>
    <profile>
      <activation>
        <activeByDefault>true</activeByDefault>
      </activation>
      <dependencies>
        <dependency>
          <artifactId>spring-boot-devtools</artifactId>
          <groupId>org.springframework.boot</groupId>
          <optional>true</optional>
          <scope>runtime</scope>
        </dependency>
      </dependencies>
      <id>dev</id>
    </profile>

    <profile>
      <dependencies>
        <dependency>
          <artifactId>hibernate-processor</artifactId>
          <groupId>org.hibernate.orm</groupId>
          <version>${hibernate.version}</version>
        </dependency>
      </dependencies>
      <id>IDE</id>
    </profile>

    <profile>
      <build>
        <plugins>
          <plugin>
            <artifactId>maven-clean-plugin</artifactId>
            <configuration>
              <filesets>
                <fileset>
                  <directory>target/classes/static/</directory>
                </fileset>
              </filesets>
            </configuration>
            <groupId>org.apache.maven.plugins</groupId>
          </plugin>
          <plugin>
            <artifactId>spring-boot-maven-plugin</artifactId>
            <executions>
              <execution>
                <goals>
                  <goal>build-info</goal>
                </goals>
              </execution>
            </executions>
            <groupId>org.springframework.boot</groupId>
          </plugin>
          <plugin>
            <artifactId>exec-maven-plugin</artifactId>
            <executions>
              <execution>
                <configuration>
                  <arguments>
                    <argument>run</argument>
                    <argument>webapp:prod</argument>
                  </arguments>
                  <environmentVariables>
                    <APP_VERSION>${project.version}</APP_VERSION>
                  </environmentVariables>
                  <executable>${npm.executable}</executable>
                  <skip>${skip.npm}</skip>
                </configuration>
                <goals>
                  <goal>exec</goal>
                </goals>
                <id>webapp build prod</id>
                <phase>generate-resources</phase>
              </execution>
            </executions>
            <groupId>org.codehaus.mojo</groupId>
            <version>${exec-maven-plugin.version}</version>
          </plugin>
        </plugins>
      </build>
      <id>prod</id>
      <properties>
        <profile.test>testprod</profile.test>
        <spring.profiles.active>prod${profile.api-docs}${profile.tls}</spring.profiles.active>
      </properties>
    </profile>

    <profile>
      <!--
        Profil full-dist : compile Angular (config tauri) avant que le JAR soit packagé.
        Le POM racine s'occupe ensuite de tauri:build:bundled-jre:fast et de l'assemblage ZIP.
        Usage : mvn clean package -DskipTests -P full-dist (depuis la racine du projet)
      -->
      <build>
        <plugins>
          <plugin>
            <artifactId>maven-clean-plugin</artifactId>
            <configuration>
              <filesets>
                <fileset>
                  <directory>target/classes/static/</directory>
                </fileset>
              </filesets>
            </configuration>
            <groupId>org.apache.maven.plugins</groupId>
          </plugin>
          <plugin>
            <artifactId>spring-boot-maven-plugin</artifactId>
            <executions>
              <execution>
                <goals>
                  <goal>build-info</goal>
                </goals>
              </execution>
            </executions>
            <groupId>org.springframework.boot</groupId>
          </plugin>
          <plugin>
            <artifactId>exec-maven-plugin</artifactId>
            <executions>
              <execution>
                <configuration>
                  <arguments>
                    <argument>run</argument>
                    <argument>webapp:build:tauri</argument>
                  </arguments>
                  <environmentVariables>
                    <APP_VERSION>${project.version}</APP_VERSION>
                  </environmentVariables>
                  <executable>${npm.executable}</executable>
                  <skip>${skip.npm}</skip>
                </configuration>
                <goals>
                  <goal>exec</goal>
                </goals>
                <id>webapp build tauri (full-dist)</id>
                <phase>generate-resources</phase>
              </execution>
            </executions>
            <groupId>org.codehaus.mojo</groupId>
            <version>${exec-maven-plugin.version}</version>
          </plugin>
        </plugins>
      </build>
      <id>full-dist</id>
      <properties>
        <spring.profiles.active>standalone</spring.profiles.active>
      </properties>
    </profile>

    <profile>
      <!-- Build Tauri desktop sans JRE (JAR seul — Java système requis).  -->
      <!-- Usage : mvn clean package -DskipTests -Pstandalone-no-jre       -->
      <!-- Produit un installeur ~80 Mo plus léger ; Java 25+ doit être     -->
      <!-- présent sur la machine cible (JAVA_HOME configuré).              -->
      <build>
        <plugins>
          <plugin>
            <artifactId>maven-clean-plugin</artifactId>
            <configuration>
              <filesets>
                <fileset>
                  <directory>target/classes/static/</directory>
                </fileset>
              </filesets>
            </configuration>
            <groupId>org.apache.maven.plugins</groupId>
          </plugin>
          <plugin>
            <artifactId>spring-boot-maven-plugin</artifactId>
            <executions>
              <execution>
                <goals>
                  <goal>build-info</goal>
                </goals>
              </execution>
            </executions>
            <groupId>org.springframework.boot</groupId>
          </plugin>
          <plugin>
            <artifactId>exec-maven-plugin</artifactId>
            <executions>
              <execution>
                <configuration>
                  <arguments>
                    <argument>run</argument>
                    <argument>tauri:build:bundled</argument>
                  </arguments>
                  <environmentVariables>
                    <APP_VERSION>${project.version}</APP_VERSION>
                  </environmentVariables>
                  <executable>${npm.executable}</executable>
                  <skip>${skip.npm}</skip>
                </configuration>
                <goals>
                  <goal>exec</goal>
                </goals>
                <id>webapp build tauri bundled (no JRE)</id>
                <phase>generate-resources</phase>
              </execution>
            </executions>
            <groupId>org.codehaus.mojo</groupId>
            <version>${exec-maven-plugin.version}</version>
          </plugin>
        </plugins>
      </build>
      <id>standalone-no-jre</id>
      <properties>
        <spring.profiles.active>standalone</spring.profiles.active>
      </properties>
    </profile>

    <profile>
      <!-- Build Tauri desktop bundled (backend JAR + JRE embarqués).     -->
      <!-- Usage : mvn clean package -DskipTests -Pstandalone              -->
      <build>
        <plugins>
          <plugin>
            <artifactId>maven-clean-plugin</artifactId>
            <configuration>
              <filesets>
                <fileset>
                  <directory>target/classes/static/</directory>
                </fileset>
              </filesets>
            </configuration>
            <groupId>org.apache.maven.plugins</groupId>
          </plugin>
          <plugin>
            <artifactId>spring-boot-maven-plugin</artifactId>
            <executions>
              <execution>
                <goals>
                  <goal>build-info</goal>
                </goals>
              </execution>
            </executions>
            <groupId>org.springframework.boot</groupId>
          </plugin>
          <plugin>
            <artifactId>exec-maven-plugin</artifactId>
            <executions>
              <execution>
                <configuration>
                  <arguments>
                    <argument>run</argument>
                    <argument>tauri:build:bundled-jre</argument>
                  </arguments>
                  <environmentVariables>
                    <APP_VERSION>${project.version}</APP_VERSION>
                  </environmentVariables>
                  <executable>${npm.executable}</executable>
                  <skip>${skip.npm}</skip>
                </configuration>
                <goals>
                  <goal>exec</goal>
                </goals>
                <id>webapp build tauri bundled-jre</id>
                <phase>generate-resources</phase>
              </execution>
            </executions>
            <groupId>org.codehaus.mojo</groupId>
            <version>${exec-maven-plugin.version}</version>
          </plugin>
        </plugins>
      </build>
      <id>standalone</id>
      <properties>
        <spring.profiles.active>standalone</spring.profiles.active>
      </properties>
    </profile>
    <!--
      Profil activé automatiquement sur Windows.
      Génère src-tauri/installer-hooks/db-defaults.json à partir des defaults
      de application-prod.yml et application.yml, pour que le formulaire NSIS
      d'installation soit pré-rempli avec les vraies valeurs par défaut Spring Boot.
    -->
    <profile>
      <activation>
        <os>
          <family>windows</family>
        </os>
      </activation>
      <build>
        <plugins>
          <plugin>
            <artifactId>exec-maven-plugin</artifactId>
            <executions>
              <execution>
                <configuration>
                  <arguments>
                    <argument>-NoProfile</argument>
                    <argument>-ExecutionPolicy</argument>
                    <argument>Bypass</argument>
                    <argument>-File</argument>
                    <argument>${project.basedir}/src/build/generate-db-defaults.ps1</argument>
                    <argument>-ProdYml</argument>
                    <argument>${project.basedir}/src/main/resources/config/application-prod.yml
                    </argument>
                    <argument>-BaseYml</argument>
                    <argument>${project.basedir}/src/main/resources/config/application.yml
                    </argument>
                    <argument>-OutFile</argument>
                    <argument>${project.basedir}/../src-tauri/installer-hooks/db-defaults.json
                    </argument>
                  </arguments>
                  <executable>powershell.exe</executable>
                </configuration>
                <goals>
                  <goal>exec</goal>
                </goals>
                <id>generate-db-defaults</id>
                <phase>generate-resources</phase>
              </execution>
            </executions>
            <groupId>org.codehaus.mojo</groupId>
          </plugin>
        </plugins>
      </build>
      <id>windows-db-defaults</id>
    </profile>
  </profiles>

  <properties>
    <start-class>com.kobe.warehouse.WarehouseApp</start-class>
  </properties>
</project>
