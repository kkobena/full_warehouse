<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Theme -->
    <style name="Base.Theme.PharmaSmart" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Brand Color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary Brand Color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Error Color -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Background Color -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Surface Color -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Apply Pharma dialog style globally -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.PharmaSmart.MaterialAlertDialog</item>
    </style>

    <!-- Main Application Theme -->
    <style name="Theme.PharmaSmart" parent="Base.Theme.PharmaSmart" />

    <!-- Splash Screen Theme -->
    <style name="Theme.PharmaSmart.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_pharma_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.PharmaSmart</item>
    </style>

    <!-- Material Alert Dialog — Pharma branded -->
    <style name="ThemeOverlay.PharmaSmart.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurface">@color/white</item>
        <item name="materialAlertDialogTitleTextStyle">@style/PharmaSmart.MaterialAlertDialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/PharmaSmart.MaterialAlertDialog.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/PharmaSmart.MaterialAlertDialog.Button.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/PharmaSmart.MaterialAlertDialog.Button.Negative</item>
        <item name="buttonBarNeutralButtonStyle">@style/PharmaSmart.MaterialAlertDialog.Button.Neutral</item>
        <item name="shapeAppearanceOverlay">@style/PharmaSmart.MaterialAlertDialog.Shape</item>
    </style>

    <style name="PharmaSmart.MaterialAlertDialog.Title" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PharmaSmart.MaterialAlertDialog.Body" parent="MaterialAlertDialog.Material3.Body.Text">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="PharmaSmart.MaterialAlertDialog.Button.Positive" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="PharmaSmart.MaterialAlertDialog.Button.Negative" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/gray_500</item>
    </style>

    <style name="PharmaSmart.MaterialAlertDialog.Button.Neutral" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/gray_500</item>
    </style>

    <style name="PharmaSmart.MaterialAlertDialog.Shape" parent="">
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Toggle Button Group — Pharma branded -->
    <style name="Widget.PharmaSmart.ToggleButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="backgroundTint">@color/toggle_button_bg</item>
        <item name="android:textColor">@color/toggle_button_text</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Full Screen Dialog Theme -->
    <style name="Theme.PharmaSmart.Dialog.FullScreen" parent="Theme.Material3.Light.Dialog">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/accent</item>
    </style>
</resources>
