<?xml version="1.0" encoding="UTF-8"?>
<!--
  Fragment WiX pour PharmaSmart.
  Crée C:\ProgramData\PharmaSmart\ avec droits Modify pour Users,
  et écrit config.json avec les chemins absolus résolus par Windows Installer.

  Fonctionne quel que soit le dossier d'installation choisi par l'utilisateur :
  les données (config, logs, rapports) sont toujours dans ProgramData,
  indépendamment de l'emplacement des binaires.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <Fragment>

    <!-- ── Répertoires dans ProgramData ─────────────────────────────────── -->
    <!--
      On étend CommonAppDataFolder (= C:\ProgramData) qui est un ID standard
      Windows Installer — pas besoin de re-déclarer TARGETDIR.
    -->
    <DirectoryRef Id="CommonAppDataFolder">
      <Directory Id="PHARMASMARTDATA" Name="PharmaSmart">
        <Directory Id="PS_LOGSDIR"     Name="logs"      />
        <Directory Id="PS_REPORTSDIR"  Name="reports"   />
        <Directory Id="PS_IMAGESDIR"   Name="images"    />
        <Directory Id="PS_JSONDIR"     Name="json"      />
        <Directory Id="PS_CSVDIR"      Name="csv"       />
        <Directory Id="PS_EXCELDIR"    Name="excel"     />
        <Directory Id="PS_PHARMAMLDIR" Name="pharmaml"  />
      </Directory>
    </DirectoryRef>

    <!-- ── Composants : création des dossiers + droits Modify pour Users ── -->
    <ComponentGroup Id="PharmaSmartDataDirs">

      <Component Id="PS_C_DataRoot" Directory="PHARMASMARTDATA"
                 Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <CreateFolder>
          <util:PermissionEx User="Users" Domain="[COMPUTERNAME]"
                             GenericRead="yes" GenericWrite="yes"
                             GenericExecute="yes" DeleteChild="yes"
                             ReadPermission="yes" />
        </CreateFolder>
      </Component>

      <Component Id="PS_C_Logs"     Directory="PS_LOGSDIR"
                 Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <CreateFolder>
          <util:PermissionEx User="Users" Domain="[COMPUTERNAME]"
                             GenericRead="yes" GenericWrite="yes"
                             GenericExecute="yes" DeleteChild="yes" />
        </CreateFolder>
      </Component>

      <Component Id="PS_C_Reports"  Directory="PS_REPORTSDIR"
                 Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <CreateFolder>
          <util:PermissionEx User="Users" Domain="[COMPUTERNAME]"
                             GenericRead="yes" GenericWrite="yes"
                             GenericExecute="yes" DeleteChild="yes" />
        </CreateFolder>
      </Component>

      <Component Id="PS_C_Images"   Directory="PS_IMAGESDIR"
                 Guid="D4E5F6A7-B8C9-0123-DEF0-234567890123">
        <CreateFolder>
          <util:PermissionEx User="Users" Domain="[COMPUTERNAME]"
                             GenericRead="yes" GenericWrite="yes"
                             GenericExecute="yes" DeleteChild="yes" />
        </CreateFolder>
      </Component>

      <Component Id="PS_C_Json"     Directory="PS_JSONDIR"
                 Guid="E5F6A7B8-C9D0-1234-EF01-345678901234">
        <CreateFolder>
          <util:PermissionEx User="Users" Domain="[COMPUTERNAME]"
                             GenericRead="yes" GenericWrite="yes"
                             GenericExecute="yes" DeleteChild="yes" />
        </CreateFolder>
      </Component>

      <Component Id="PS_C_Csv"      Directory="PS_CSVDIR"
                 Guid="F6A7B8C9-D0E1-2345-F012-456789012345">
        <CreateFolder>
          <util:PermissionEx User="Users" Domain="[COMPUTERNAME]"
                             GenericRead="yes" GenericWrite="yes"
                             GenericExecute="yes" DeleteChild="yes" />
        </CreateFolder>
      </Component>

      <Component Id="PS_C_Excel"    Directory="PS_EXCELDIR"
                 Guid="A7B8C9D0-E1F2-3456-0123-567890123456">
        <CreateFolder>
          <util:PermissionEx User="Users" Domain="[COMPUTERNAME]"
                             GenericRead="yes" GenericWrite="yes"
                             GenericExecute="yes" DeleteChild="yes" />
        </CreateFolder>
      </Component>

      <Component Id="PS_C_Pharmaml" Directory="PS_PHARMAMLDIR"
                 Guid="B8C9D0E1-F2A3-4567-1234-678901234567">
        <CreateFolder>
          <util:PermissionEx User="Users" Domain="[COMPUTERNAME]"
                             GenericRead="yes" GenericWrite="yes"
                             GenericExecute="yes" DeleteChild="yes" />
        </CreateFolder>
      </Component>

    </ComponentGroup>

    <!-- ── Action personnalisée : écriture de config.json ────────────────── -->
    <!--
      Type 34 (Exe depuis un répertoire) : plus simple et plus fiable que WixQuietExec.
      [PHARMASMARTDATA] et [INSTALLDIR] sont résolus par Windows Installer
      AVANT d'être passés à cmd.exe — quel que soit le dossier choisi par l'utilisateur.

      [INSTALLDIR] peut se terminer par "\" ; on utilise des guillemets doubles
      dans PowerShell pour les chemins (pas de problème avec les antislashs).

      Return="ignore" : si PowerShell échoue (politique restrictive, etc.),
      l'installation continue — le runtime Rust créera les dossiers et utilisera
      ses valeurs par défaut.
    -->
    <CustomAction Id="PS_WriteConfigJson"
                  Directory="PHARMASMARTDATA"
                  ExeCommand="[SystemFolder]cmd.exe /C powershell.exe -NoProfile -ExecutionPolicy Bypass -Command &quot;$d=[System.Environment]::GetFolderPath('CommonApplicationData') + '\PharmaSmart'; $inst='[INSTALLDIR]'.TrimEnd('\'); $cfg = [ordered]@{ server=@{port=9080}; logging=@{directory=&quot;&quot;$d\logs&quot;&quot;;file=&quot;&quot;$d\logs\pharmasmart.log&quot;&quot;}; installation=@{directory=$inst}; jvm=@{heap_min='2g';heap_max='2g';metaspace_size='256m';metaspace_max='384m';direct_memory_size='384m';max_gc_pause_millis='200';additional_options=@()}; file=@{report=&quot;&quot;$d\reports&quot;&quot;;images=&quot;&quot;$d\images&quot;&quot;;import=@{json=&quot;&quot;$d\json&quot;&quot;;csv=&quot;&quot;$d\csv&quot;&quot;;excel=&quot;&quot;$d\excel&quot;&quot;};pharmaml=&quot;&quot;$d\pharmaml&quot;&quot;}; fne=@{url='';'api-key'='';'point-of-sale'=''}; mail=@{username='';email=''}; 'port-com'=''; database=@{url='';username='';password='';schema=''}; backup=@{directory=&quot;&quot;$d\backups&quot;&quot;;db='pharma_smart';host='localhost';port=5432;user='pharma_smart';retention_daily_days=30;retention_base_weeks=4;wal_archiving=$false;wal_directory=''}} | ConvertTo-Json -Depth 10 | Out-File -Encoding UTF8 &quot;&quot;$d\config.json&quot;&quot;&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Copy config.json to [INSTALLDIR] so it is visible next to the EXE
         (config_search_dirs() Priority 2 = exe dir). Return="ignore" to not
         block installation if the source does not exist yet (timing issue). -->
    <CustomAction Id="PS_CopyConfigToInstDir"
                  Directory="INSTALLDIR"
                  ExeCommand="[SystemFolder]cmd.exe /C copy /Y &quot;[CommonAppDataFolder]PharmaSmart\config.json&quot; &quot;[INSTALLDIR]config.json&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!--
      Installation du service Windows pharmasmart-app via WinSW.
      Le script détecte automatiquement le JAR, java.exe et le port depuis config.json.
      Le mot de passe base de données n'est PAS géré ici — il doit être défini
      comme variable d'environnement système (PHARMA_DB_PASSWORD) par l'administrateur.
      Return="ignore" : l'installation continue même si le service échoue (pas d'internet,
      pas de Java système, etc.) — l'admin peut relancer le script manuellement.
    -->
    <CustomAction Id="PS_InstallBackendService"
                  Directory="INSTALLDIR"
                  ExeCommand="[SystemFolder]cmd.exe /C powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLDIR]resources\service\setup-backend-service.ps1&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!--
      Suppression du service avant la désinstallation des fichiers.
      Exécuté avant RemoveFiles pour que le script PowerShell soit encore accessible.
      Ignoré lors d'une mise à jour (UPGRADINGPRODUCTCODE) : le nouveau MSI
      réinstallera le service avec la bonne version du JAR.
    -->
    <CustomAction Id="PS_RemoveBackendService"
                  Directory="INSTALLDIR"
                  ExeCommand="[SystemFolder]cmd.exe /C powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLDIR]resources\service\remove-backend-service.ps1&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!--
      Tue le processus Java backend avant la suppression des fichiers.
      Nécessaire quand le backend tourne comme processus direct (non-service) :
      sans cet arrêt, le JAR et le JRE restent verrouillés par la JVM et
      l'application reste accessible sur le port même après désinstallation.
      Stratégie : CimInstance en priorité, fallback WMI, puis fallback port TCP.
    -->
    <CustomAction Id="PS_StopBackendProcess"
                  Directory="INSTALLDIR"
                  ExeCommand="[SystemFolder]cmd.exe /C powershell.exe -NoProfile -ExecutionPolicy Bypass -Command &quot;$killed=$false; try { Get-CimInstance -ClassName Win32_Process -Filter 'Name LIKE ''java%''' -ErrorAction Stop | Where-Object { $_.CommandLine -like '*pharmaSmart*' -or $_.CommandLine -like '*pharmasmart*' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue; $killed=$true } } catch { Get-WmiObject Win32_Process -ErrorAction SilentlyContinue | Where-Object { $_.Name -like 'java*' -and $_.CommandLine -like '*pharmasmart*' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue; $killed=$true } }; if (-not $killed) { Get-NetTCPConnection -LocalPort 9080 -State Listen -ErrorAction SilentlyContinue | Where-Object { $_.OwningProcess -gt 4 } | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue } }; Start-Sleep -Seconds 3&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- Après InstallFiles : les dossiers existent, PHARMASMARTDATA est résolu -->
      <Custom Action="PS_WriteConfigJson" After="InstallFiles">NOT Installed OR REINSTALL</Custom>
      <!-- Copie dans le dossier d'installation juste après la création dans ProgramData -->
      <Custom Action="PS_CopyConfigToInstDir" After="PS_WriteConfigJson">NOT Installed OR REINSTALL</Custom>
      <!-- Service install : après la config, uniquement installation/réinstallation -->
      <Custom Action="PS_InstallBackendService" After="PS_CopyConfigToInstDir">(NOT Installed OR REINSTALL) AND NOT REMOVE</Custom>
      <!-- Tue le processus Java (direct ou service) avant suppression des fichiers -->
      <Custom Action="PS_StopBackendProcess" Before="PS_RemoveBackendService">Installed AND REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
      <!-- Service remove : avant la suppression des fichiers, uniquement désinstallation complète -->
      <Custom Action="PS_RemoveBackendService" Before="RemoveFiles">Installed AND REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>

    <!-- ── Feature autonome pour les données PharmaSmart ─────────────────── -->
    <!--
      Feature séparée de la feature principale Tauri pour éviter les conflits d'ID.
      Elle est toujours installée (Level="1") et non affichée dans l'UI (Display="hidden").
    -->
    <Feature Id="PS_DataFeature" Title="Données PharmaSmart" Level="1" Display="hidden">
      <ComponentGroupRef Id="PharmaSmartDataDirs" />
    </Feature>

  </Fragment>

</Wix>
