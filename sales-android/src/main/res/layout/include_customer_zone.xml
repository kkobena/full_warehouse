<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardCustomerZone"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header with expand/collapse -->
        <LinearLayout
            android:id="@+id/layoutCustomerHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/client"
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tvCustomerRequired"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/obligatoire"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorError"
                android:visibility="gone"
                tools:visibility="visible" />

            <ImageView
                android:id="@+id/ivExpandCustomer"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/expand_collapse"
                android:src="@drawable/ic_expand_more"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <!-- Customer Search (Expandable) -->
        <LinearLayout
            android:id="@+id/layoutCustomerContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- Search Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCustomerSearch"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/rechercher_client"
                app:endIconDrawable="@drawable/ic_search"
                app:endIconMode="custom"
                app:startIconDrawable="@drawable/ic_person"
                app:boxStrokeWidth="1dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCustomerSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Loading Indicator for Customer Search -->
            <LinearLayout
                android:id="@+id/layoutCustomerSearchLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="8dp"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:indeterminate="true"
                    app:indicatorSize="20dp"
                    app:trackThickness="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Recherche en cours..."
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <!-- Empty State for Customer Search -->
            <TextView
                android:id="@+id/tvCustomerSearchEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:padding="12dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"
                tools:text="Aucun client trouvé"
                tools:visibility="visible" />

            <!-- Customer Search Results (RecyclerView) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCustomerSearchResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:maxHeight="180dp"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                tools:itemCount="3"
                tools:listitem="@layout/item_customer_search"
                tools:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
