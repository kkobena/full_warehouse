<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Taux de couverture -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilTaux"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Taux de couverture (%)"
        app:endIconMode="clear_text"
        app:helperText="Entre 0 et 100"
        app:helperTextEnabled="true">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTaux"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLength="3" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Priorité -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Priorité"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <Spinner
        android:id="@+id/spinnerPriorite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_spinner"
        android:minHeight="48dp"
        android:padding="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="R0 = Principal\nC1, C2, C3 = Complémentaires"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

</LinearLayout>
