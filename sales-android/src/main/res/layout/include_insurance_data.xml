<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardInsuranceData"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/donnees_assurance"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="?attr/colorOnSurface" />

        <!-- Selected Tiers Payants Summary -->
        <TextView
            android:id="@+id/tvTiersPayants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:background="?attr/colorSurfaceVariant"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            tools:visibility="visible"
            tools:text="Principal: CNAM (80%), Complémentaire: Mutuelle Santé (15%)" />

        <!-- Tiers Payant Principal -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTiersPayantPrincipal"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/tiers_payant_principal">

            <AutoCompleteTextView
                android:id="@+id/actvTiersPayantPrincipal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Taux Couverture Principal -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTauxCouverturePrincipal"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/taux_couverture_principal"
            app:suffixText="%">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTauxCouverturePrincipal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLines="1"
                tools:text="80" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Type Prescription -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPrescriptionType"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/type_prescription">

            <AutoCompleteTextView
                android:id="@+id/actvPrescriptionType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Numero Bon (visible only for certain prescription types) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNumeroBon"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/numero_bon"
            android:visibility="gone"
            tools:visibility="visible">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNumeroBon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Ayant Droit Selection (optional) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectAyantDroit"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/selectionner_ayant_droit"
            app:icon="@drawable/ic_person_add" />

        <!-- Selected Ayant Droit Info -->
        <LinearLayout
            android:id="@+id/layoutSelectedAyantDroit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="?attr/colorSurfaceVariant"
            android:orientation="horizontal"
            android:padding="12dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tvAyantDroitName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                tools:text="Marie Dupont (Bénéficiaire)" />

            <ImageButton
                android:id="@+id/btnRemoveAyantDroit"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/remove"
                android:src="@drawable/ic_close"
                app:tint="?attr/colorError" />

        </LinearLayout>

        <!-- Add Tiers Payant Complementaire Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddTiersPayantComplementaire"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/ajouter_tiers_payant_complementaire"
            app:icon="@drawable/ic_add" />

        <!-- Tiers Payants Complementaires List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTiersPayantsComplementaires"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            tools:itemCount="1"
            tools:listitem="@layout/item_tiers_payant_complementaire"
            tools:visibility="visible" />

        <!-- Coverage Summary -->
        <LinearLayout
            android:id="@+id/layoutCoverageSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="?attr/colorPrimaryContainer"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/repartition_paiement"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textColor="?attr/colorOnPrimaryContainer" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/part_assurance"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                <TextView
                    android:id="@+id/tvInsurancePart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textStyle="bold"
                    tools:text="80,000 FCFA (80%)" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/part_client"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                <TextView
                    android:id="@+id/tvClientPart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textStyle="bold"
                    tools:text="20,000 FCFA (20%)" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
