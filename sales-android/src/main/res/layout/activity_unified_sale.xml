<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fitsSystemWindows="true"
    tools:context=".ui.activity.UnifiedSaleActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/nouvelle_vente"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:paddingBottom="100dp">

            <!-- Plafond Vente Warning Banner -->
            <LinearLayout
                android:id="@+id/plafondWarningBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/warning_light"
                android:padding="8dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_warning"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Warning" />

                <TextView
                    android:id="@+id/tvPlafondWarningMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/gray_800"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Sale Type Selector -->
            <include
                android:id="@+id/includeSaleTypeSelector"
                layout="@layout/include_sale_type_selector" />

            <!-- Customer Zone (mandatory for Assurance/Carnet) -->
            <include
                android:id="@+id/includeCustomerZone"
                layout="@layout/include_customer_zone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <!-- Customer Info Display (shows selected customer + tiers payants + ayant droit) -->
            <include
                android:id="@+id/includeCustomerInfoDisplay"
                layout="@layout/include_customer_info_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <!-- Product Search & Cart -->
            <include
                android:id="@+id/includeProductCart"
                layout="@layout/include_product_cart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Bar with Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <!-- Total Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <!-- Total Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    tools:text="15,000 FCFA" />

            </LinearLayout>

            <!-- TVA Row -->
            <LinearLayout
                android:id="@+id/rowTva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TVA"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvTva"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    tools:text="500 FCFA" />

            </LinearLayout>

            <!-- Remise Row -->
            <LinearLayout
                android:id="@+id/rowRemise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Remise"
                    android:textSize="13sp"
                    android:textColor="@color/success" />

                <TextView
                    android:id="@+id/tvRemise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/success"
                    tools:text="-1,000 FCFA" />

            </LinearLayout>

            <!-- Tiers Payant Details Container (dynamic rows per insurer) -->
            <LinearLayout
                android:id="@+id/containerTiersPayantDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="2dp"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- A Payer Row (patient share for Assurance/Carnet) -->
            <LinearLayout
                android:id="@+id/rowAmountToBePaid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="A payer"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAmountToBePaid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    tools:text="3,000 FCFA" />

            </LinearLayout>

        </LinearLayout>

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Put On Hold Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPutOnHold"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/mettre_en_attente"
                android:textSize="13sp"
                android:textAllCaps="false"
                app:icon="@drawable/ic_pause"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <!-- Finalize Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinalizeSale"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/finaliser_vente"
                android:textSize="13sp"
                android:textAllCaps="false"
                app:icon="@drawable/ic_check"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:cornerRadius="8dp"
                android:backgroundTint="@color/success"
                android:textColor="@color/white" />

        </LinearLayout>

    </LinearLayout>

    <!-- Progress Bar -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminate="true"
        app:indicatorColor="@color/primary"
        tools:visibility="visible" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
